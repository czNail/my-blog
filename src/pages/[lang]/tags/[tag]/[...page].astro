---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { SITE } from "@/config";
import { getPostsByLang, isLang, LANGS, ui } from "@/i18n";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");

  return LANGS.flatMap(lang => {
    const localizedPosts = getPostsByLang(posts, lang);
    const tags = getUniqueTags(localizedPosts);

    return tags.flatMap(({ tag, tagName }) => {
      const tagPosts = getPostsByTag(localizedPosts, tag);

      return paginate(tagPosts, {
        params: { lang, tag },
        props: { tagName },
        pageSize: SITE.postPerPage,
      });
    });
  });
}

const params = Astro.params;
const { tag } = params;
const { page, tagName } = Astro.props;
const lang = isLang(Astro.params.lang) ? Astro.params.lang : "en";
const t = ui[lang];
---

<Layout
  title={`${t.tagTitle} ${tagName} | ${t.siteTitle}`}
  description={t.siteDesc}
>
  <Header />
  <Main
    pageTitle={[t.tagTitle, `${tagName}`]}
    titleTransition={tag}
    pageDesc={lang === "zh"
      ? `所有带有 "${tagName}" 标签的文章。`
      : `All the articles with the tag "${tagName}".`}
  >
    <h1 slot="title" transition:name={tag}>{`${t.tagTitle}${tag}`}</h1>
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
