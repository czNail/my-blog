---
import { getBasePath } from "@/utils/getBasePath";

const zhPath = getBasePath("/zh/");
const enPath = getBasePath("/en/");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Neil's Blog</title>
    <script is:inline define:vars={{ zhPath, enPath }}>
      const preferredLanguage = navigator.language || "";
      const target = preferredLanguage.toLowerCase().startsWith("zh")
        ? zhPath
        : enPath;

      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>
      <a href={enPath}>English</a>
      <span> / </span>
      <a href={zhPath}>中文</a>
    </p>
  </body>
</html>
